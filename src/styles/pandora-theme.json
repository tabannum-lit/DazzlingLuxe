{
  "colors": {
    "cream": "#FFF8F0",
    "ivory": "#FFFFF0",
    "beige": "#F5E6D3",
    "warm-gold": "#C8A96E",
    "deep-gold": "#A67C52",
    "blush": "#F2D4C2",
    "charcoal": "#2C2C2C",
    "soft-brown": "#6B5B4F",
    "light-gold": "#E8D5B7",
    "pale-rose": "#F9EDE6",
    "white": "#FFFFFF"
  },
  "typography": {
    "headings": "Cormorant Garamond, serif",
    "body": "Lato, -apple-system, sans-serif",
    "logo": "Great Vibes, cursive",
    "sizes": {
      "h1": "3.75rem",
      "h2": "3rem",
      "h3": "2.25rem",
      "h4": "1.875rem",
      "base": "1rem",
      "lg": "1.125rem"
    }
  },
  "spacing": {
    "section": "5rem",
    "container": "1.5rem",
    "grid-gap": "1.5rem",
    "product-padding": "1.25rem"
  },
  "shadows": {
    "header": "0 4px 20px rgba(200, 169, 110, 0.08)",
    "card": "0 4px 15px rgba(200, 169, 110, 0.1)",
    "hover": "0 20px 40px rgba(200, 169, 110, 0.15)"
  },
  "transitions": {
    "all": "all 0.3s cubic-bezier(0.4, 0, 0.2, 1)",
    "hover": "transform 0.4s ease"
  },
  "border-radius": {
    "sm": "0.5rem",
    "md": "0.75rem",
    "lg": "1rem",
    "full": "9999px"
  },
  "z-index": {
    "header": "50",
    "cart": "100",
    "modal": "1000"
  }
}
